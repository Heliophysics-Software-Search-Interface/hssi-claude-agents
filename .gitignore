# macOS
.DS_Store

# Environment variables (tokens, secrets)
.env

# Claude Code local settings
.claude/settings.local.json

# Cloned repos — only track the extracted hssi_metadata.md files
# One-level (repos/<software>/) and two-level (repos/<collection>/<paper>/) layouts.
# Each level un-ignores only its own subdirs so git never descends deeper (no leaks).
repos/**
!repos/*/
!repos/*/hssi_metadata.md
!repos/*/*/
!repos/*/*/hssi_metadata.md

# Payloads — only track reference examples
payloads/*
!payloads/.gitkeep
!payloads/example_submission.json
