# macOS
.DS_Store

# Environment variables (tokens, secrets)
.env

# Claude Code local settings
.claude/settings.local.json

# Cloned repos — only track the extracted hssi_metadata.md files
repos/**
!repos/*/
!repos/*/hssi_metadata.md

# Modelling software clones — only track the extracted hssi_metadata.md files
# One-level (models/<software>/) and two-level (models/<collection>/<paper>/) layouts.
# Each level un-ignores only its own subdirs so git never descends deeper (no leaks).
models/**
!models/*/
!models/*/hssi_metadata.md
!models/*/*/
!models/*/*/hssi_metadata.md

# Payloads — only track reference examples
payloads/*
!payloads/.gitkeep
!payloads/example_submission.json
